{
  "name": "rafters-workspace",
  "private": true,
  "type": "module",
  "description": "",
  "author": "Andrew Hite <andy@andyhite.com> (https://andyhite.com)",
  "scripts": {
    "build": "pnpm --filter @andyhite/rafters build",
    "test": "pnpm --filter @andyhite/rafters test",
    "lint": "pnpm --filter @andyhite/rafters lint",
    "storybook": "NODE_NO_WARNINGS=1 storybook dev -p 6006 --quiet",
    "build-storybook": "NODE_NO_WARNINGS=1 storybook build",
    "serve-storybook": "http-server storybook-static --port 6006 --silent",
    "test-storybook": "test-storybook --url http://127.0.0.1:6006",
    "test-storybook:ci": "start-server-and-test serve-storybook http://127.0.0.1:6006 test-storybook",
    "tool-versions": "sh -c './scripts/tool-versions.sh $1' --"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.2",
    "@emotion/styled": "^11.13.5",
    "@fontsource/material-icons": "^5.1.0",
    "@fontsource/roboto": "^5.1.0",
    "@microsoft/api-extractor": "^7.48.0",
    "@mui/material": "^6.1.10",
    "@storybook/addon-actions": "^8.4.7",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-themes": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/builder-vite": "^8.4.7",
    "@storybook/experimental-addon-test": "^8.4.7",
    "@storybook/preview-api": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@storybook/test": "^8.4.7",
    "@storybook/test-runner": "^0.19.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^3.0.0-beta.1",
    "@vitest/mocker": "3.0.0-beta.1",
    "chalk": "^5.3.0",
    "eslint-config-xo": "^0.46.0",
    "eslint-config-xo-react": "^0.27.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "http-server": "^14.1.1",
    "jsdom": "^25.0.1",
    "playwright": "^1.49.0",
    "prettier": "^3.4.2",
    "react-hook-form": "^7.53.2",
    "react-hook-form-mui": "^7.4.1",
    "rollup": "^4.28.1",
    "start-server-and-test": "^2.0.8",
    "storybook": "^8.4.7",
    "type-fest": "^4.30.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.0.0-beta.1",
    "xo": "^0.59.3"
  }
}
